{
  "permissions": {
    "deny": [
      "Bash(git push origin main*)",
      "Bash(git push origin master*)",
      "Bash(git push origin prod*)",
      "Bash(git push origin dev*)",
      "Bash(git push origin int*)",
      "Bash(git push origin release/*)",
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Bash(git push -f)",
      "Bash(git push --force-with-lease*)",
      "Bash(git push * --force*)",
      "Bash(git push * -f *)",
      "Bash(git push * -f)",
      "Bash(git push * --force-with-lease*)",
      "Bash(git reset --hard*)",
      "Bash(git checkout .)",
      "Bash(git checkout -- *)",
      "Bash(git restore .)",
      "Bash(git clean -f*)",
      "Bash(git branch -D *)",
      "Bash(git branch -D)",
      "Bash(git merge --squash*)",
      "Bash(git rebase*)",
      "Bash(gh pr merge --rebase*)",
      "Read(~/.zshrc)",
      "Read(~/.zshrc.*)",
      "Read(~/.zprofile)",
      "Read(~/.zprofile.*)",
      "Read(~/.bashrc)",
      "Read(~/.bashrc.*)",
      "Read(~/.bash_profile)",
      "Read(~/.bash_profile.*)",
      "Read(~/.profile)",
      "Read(~/.env)",
      "Read(~/.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(~/.aws/**)",
      "Read(~/.gcloud/**)",
      "Read(~/.kube/config)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*.p12)",
      "Read(**/*.pfx)",
      "Read(**/*.pkcs12)",
      "Read(**/*.jks)",
      "Read(**/*.keystore)",
      "Read(**/*.cer)",
      "Read(**/*.crt)",
      "Read(**/*.ppk)",
      "Read(**/id_rsa)",
      "Read(**/id_rsa.*)",
      "Read(**/id_ed25519)",
      "Read(**/id_ed25519.*)",
      "Read(**/id_ecdsa)",
      "Read(**/id_ecdsa.*)",
      "Read(**/*.asc)",
      "Read(**/*.gpg)",
      "Read(**/*.token)",
      "Read(**/*.secret)",
      "Read(**/*credentials*)",
      "Read(**/*secrets*)",
      "Read(**/terraform.tfvars)",
      "Read(**/*.tfstate)",
      "Read(**/*.tfstate.*)",
      "Read(**/vault-token)",
      "Read(**/.vault-token)",
      "Read(~/.secrets/**)",
      "Read(**/*kubeconfig*.yaml)",
      "Read(**/*kubeconfig*.json)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/bash_command_validator_example.py"
          }
        ]
      }
    ]
  }
}
